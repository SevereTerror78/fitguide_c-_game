using System;
using System.Drawing;
using System.Windows.Forms;

namespace game
{
    // Example power-down: slows shrink rate (placeholder behaviour)
    public class PowerDownSlow : PowerDownBase
    {
        public PowerDownSlow(Form3 form) : base(form)
        {
            button.Text = "-5p";
            try { button.BackColor = Color.OrangeRed; } catch { }
        }

        protected override void OnHit()
        {
            int score = form.Engine.GetElapsedTime();
            int newScore = Math.Max(0, score - 5);
            form.Engine.SetElapsedTime(newScore);
            MessageBox.Show("Shrink rate slowed (simulated) and -5 points", "PowerDown", MessageBoxButtons.OK, MessageBoxIcon.Information);
        }
    }
}
