namespace game
{
    public partial class Form2 : Form
    {
        private readonly UserManager userManager;
        private TextBox emailBox;
        private TextBox passwordBox;

        public Form2(UserManager userManager)
        {
            InitializeComponent();
            this.userManager = userManager ?? throw new ArgumentNullException(nameof(userManager));
            InitLayout();
            this.Load += Form2_Load;
        }

        private void Form2_Load(object sender, EventArgs e)
        {
            this.Size = new Size(1000, 800);
            this.Text = "Login/Register";

            var last = userManager.LoadLastEmail();
            if (!string.IsNullOrWhiteSpace(last))
            {
                emailBox.Text = last;
                passwordBox.Focus();
            }
        }

        private void InitLayout()
        {
            GroupBox loginBox = new GroupBox
            {
                Name = "login",
                Text = "Login",
                Size = new Size(400, 300),
                Location = new Point(100, 100),
                BackColor = Color.FromArgb(91, 133, 196)
            };
            this.Controls.Add(loginBox);

            int startY = 40;
            int labelWidth = 100;
            int textBoxWidth = 200;
            int height = 30;
            int spacing = 40;

            Label emailLabel = new Label 
            {   
                Text = "Email:", 
                Location = new Point(30, startY),
                Size = new Size(labelWidth, height) 
            };

            loginBox.Controls.Add(emailLabel);

            emailBox = new TextBox 
            { 
                Name = "email", 
                Location = new Point(130, startY),
                Size = new Size(textBoxWidth, height) };
            loginBox.Controls.Add(emailBox);

            Label passwordLabel = new Label 
            {
                Text = "Jelszó:", 
                Location = new Point(30, startY + spacing), 
                Size = new Size(labelWidth, height) 
            };
            loginBox.Controls.Add(passwordLabel);

            passwordBox = new TextBox 
            { 
                Name = "password", 
                UseSystemPasswordChar = true, 
                Location = new Point(130, startY + spacing), 
                Size = new Size(textBoxWidth, height) 
            };
            loginBox.Controls.Add(passwordBox);

            Button loginButton = new Button 
            { 
                Text = "Bejelentkezés", 
                Size = new Size(150, 40), 
                Location = new Point(125, startY + spacing * 2) 
            };
            loginButton.Click += (s, e) => DoLogin();
            loginBox.Controls.Add(loginButton);


            Button backButton = new Button 
            { 
                Text = "Back", 
                Size = new Size(150, 40), 
                Location = new Point(650, 650) 
            };
            backButton.Click += (s, e) => this.Close();
            this.Controls.Add(backButton);
        }

        private void DoLogin()
        {
            string email = emailBox.Text.Trim();
            string pwd = passwordBox.Text;
            if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(pwd))
            {
                MessageBox.Show("You didn't fill everything!", "error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                return;
            }

            if (userManager.TryLogin(email, pwd, out string failMsg))
            {
                MessageBox.Show($"Login successful! Welcome {userManager.CurrentUserName}");
                this.DialogResult = DialogResult.OK;
                this.Close();
            }
            else
            {
                MessageBox.Show(failMsg ?? "Login failed", "Login Failed", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
    }
}

