        /// <summary>
        /// Handler called by the game engine when the player shoots a bullet.
        /// Creates a bullet UI panel and starts its movement.
        /// </summary>
        /// <param name="center">The shooting origin point.</param>
        /// <param name="mousePos">The target mouse position.</param>
        private void Engine_OnShootBullet(Point center, Point mousePos)
        {
            this.Invoke((MethodInvoker)(() =>
            {
                Panel bullet = new Panel { Size = new Size(10, 10), BackColor = Color.Red, Location = new Point(center.X - 5, center.Y - 5) };
                bullet.Tag = CalculateDirection(center, mousePos);
                this.Controls.Add(bullet);
                StartBulletMovement(bullet);
            }));
        }

        /// <summary>
        /// Starts movement for the given bullet panel. Handles bullet updates, collision
        /// checks against power items and removal when leaving the play area.
        /// </summary>
        /// <param name="bullet">The bullet panel to animate.</param>
        private void StartBulletMovement(Panel bullet)
        {
            System.Windows.Forms.Timer movementTimer = new System.Windows.Forms.Timer { Interval = 15 };
            movementTimer.Tick += (s, e) =>
            {
                PointF dir = (PointF)bullet.Tag;
                int speed = 10;
                bullet.Left += (int)(dir.X * speed);
                bullet.Top += (int)(dir.Y * speed);

                // check collisions with all active power items
                for (int i = powerItems.Count - 1; i >= 0; i--)
                {
                    var pd = powerItems[i];
                    if (pd == null) { powerItems.RemoveAt(i); continue; }

                    if (pd.Active)
                    {
                        pd.CheckBulletCollision(bullet, movementTimer);
                        if (!bullet.Visible)
                            break; // bullet consumed
                    }
                    else
                    {
                        // clean up finished power items
                        powerItems.RemoveAt(i);
                    }
                }

                if (!bullet.Visible) return;

                if (bullet.Left <= 0 || bullet.Right >= this.ClientSize.Width || bullet.Top <= 0 || bullet.Bottom >= this.ClientSize.Height)
                {
                    movementTimer.Stop();
                    movementTimer.Dispose();
                    HandleBulletImpact(bullet);
                }
            };

            movementTimer.Start();
        }

        /// <summary>
        /// Calculates a normalized direction vector from start to target.
        /// Returns a PointF representing the unit vector direction.
        /// </summary>
        /// <param name="start">Starting point.</param>
        /// <param name="target">Target point.</param>
        /// <returns>Normalized direction vector as PointF.</returns>
        private PointF CalculateDirection(Point start, Point target)
        {
            float dx = target.X - start.X;
            float dy = target.Y - start.Y;
            float length = (float)Math.Sqrt(dx * dx + dy * dy);
            if (length == 0) return new PointF(0, 0);
            return new PointF(dx / length, dy / length);
        }

        /// <summary>
        /// Handles the impact when a bullet hits the boundary of the play area.
        /// Expands the window on the side that was hit and disposes the bullet.
        /// </summary>
        /// <param name="bullet">The bullet that impacted.</param>
        private void HandleBulletImpact(Panel bullet)
        {
            bool hitLeft = bullet.Left <= 0;
            bool hitRight = bullet.Right >= this.ClientSize.Width;
            bool hitTop = bullet.Top <= 0;
            bool hitBottom = bullet.Bottom >= this.ClientSize.Height;

            int growAmount = 50;

            if (hitLeft)
            {
                this.Left -= growAmount;
                this.Width += growAmount;
            }
            else if (hitRight)
            {
                this.Width += growAmount;
            }

            if (hitTop)
            {
                this.Top -= growAmount;
                this.Height += growAmount;
            }
            else if (hitBottom)
            {
                this.Height += growAmount;
            }

            bullet.Dispose();
        }

        /// <summary>
        /// Handler called by the game engine when the game ends. Persists score,
        /// possibly awards rewards and shows final messages, then closes the form.
        /// </summary>
        private void Engine_OnGameEnded()
        {
            // mark game ended so other UI (pause dialog) won't appear
            gameEndedFlag = true;
            int finalScore = engine.GetElapsedTime();
            // marshal to UI thread to run finish logic
            try { this.Invoke((MethodInvoker)(() => FinishGame(finalScore))); } catch { FinishGame(finalScore); }
        }

        /// <summary>
        /// Finishes the game: persists score, awards discount if applicable, shows messages and closes the form.
        /// This method must be called on the UI thread.
        /// </summary>
        /// <param name="finalScore">Final elapsed time/score.</param>
        private void FinishGame(int finalScore)
        {
            if (gameEndedFlag == false) gameEndedFlag = true;
            try
            {
                scoreManager.AppendScore(username, finalScore);
            }
            catch { }

            if (finalScore > 50)
            {
                try
                {
                    int userId = userManager.CurrentUserId;
                    string coupon = CouponGenerator.Generate(12);
                    DateTime expiry = DateTime.Now.AddDays(7);
                    decimal amount = 15;
                    DatabaseHelper.InsertDiscount(userId, coupon, expiry, amount);
                    MessageBox.Show($"Gratulálunk!\nNyertél egy kupont:\n\n{coupon}\n\nÉrvényes: {expiry:yyyy-MM-dd}", "Kupon nyertél!", MessageBoxButtons.OK, MessageBoxIcon.Information);
                }
                catch { }
            }

            MessageBox.Show("The game has ended!", "Game over!", MessageBoxButtons.OK, MessageBoxIcon.Information);

            // cleanup power items and spawner
            try { powerItemSpawner?.Stop(); powerItemSpawner?.Dispose(); } catch { }
            foreach (var pd in powerItems) pd?.Destroy();
            powerItems.Clear();

            try { this.Close(); } catch { }
        }

        /// <summary>
        /// Form closing override to stop the engine and cleanup power items and timers.
        /// </summary>
        /// <param name="e">Form closing event args.</param>
        protected override void OnFormClosing(FormClosingEventArgs e)
        {
            // ensure we mark closing-by-user if the close reason indicates user action
            try { if (e.CloseReason == CloseReason.UserClosing) isClosingByUser = true; } catch { }

            engine?.Stop();
            try { powerItemSpawner?.Stop(); powerItemSpawner?.Dispose(); } catch { }
            foreach (var pd in powerItems) pd?.Destroy();
            powerItems.Clear();
            try { barrelTimer?.Stop(); barrelTimer?.Dispose(); } catch { }
            base.OnFormClosing(e);
        }

        private const int WM_SYSCOMMAND = 0x0112;
        private const int SC_CLOSE = 0xF060;

        /// <summary>
        /// Intercept close messages (clicking the X or Alt+F4) so we can detect user-initiated close
        /// before Deactivate is fired and avoid showing the pause dialog.
        /// </summary>
        /// <param name="m"></param>
        protected override void WndProc(ref Message m)
        {
            try
            {
                if (m.Msg == WM_SYSCOMMAND)
                {
                    int wp = m.WParam.ToInt32() & 0xFFF0;
                    if (wp == SC_CLOSE)
                    {
                        isClosingByUser = true;
                    }
                }
            }
            catch { }
            base.WndProc(ref m);
        }

        /// <summary>
        /// When the form loses focus, pause the game and show a modal dialog asking
        /// the user to continue. Resume after the user confirms.
        /// </summary>
        /// <param name="e"></param>
        protected override void OnDeactivate(EventArgs e)
        {
            base.OnDeactivate(e);
            try
            {
                if (gameEndedFlag) return;
                if (isClosingByUser) return; // do not show pause dialog when user is closing the form
                // pause engine
                engine?.Pause();

                if (this.IsDisposed || !this.IsHandleCreated) return;

                // show modal dialog asking to continue
                MessageBox.Show(this, "The game is paused because the window lost focus. Click OK to continue.", "Game paused", MessageBoxButtons.OK, MessageBoxIcon.Information);

                // resume engine when user acknowledges
                engine?.Resume();
            }
            catch { }
        }

        /// <summary>
        /// Paint the barrel (a fixed-length gray line starting from the player center towards the cursor).
        /// </summary>
        protected override void OnPaint(PaintEventArgs e)
        {
            base.OnPaint(e);

            try
            {
                if (playerBtn != null && playerBtn.Visible && barrelTimer != null)
                {
                    var g = e.Graphics;
                    g.SmoothingMode = System.Drawing.Drawing2D.SmoothingMode.AntiAlias;

                    float sx = playerBtn.Left + playerBtn.Width / 2f;
                    float sy = playerBtn.Top + playerBtn.Height / 2f;

                    float dx = barrelTarget.X - sx;
                    float dy = barrelTarget.Y - sy;
                    float len = (float)Math.Sqrt(dx * dx + dy * dy);
                    if (len < 1) len = 1;
                    float ex = sx + dx / len * barrelLength;
                    float ey = sy + dy / len * barrelLength;

                    using (var pen = new Pen(Color.Gray, 8))
                    using (var penInner = new Pen(Color.DarkGray, 2))
                    {
                        pen.StartCap = System.Drawing.Drawing2D.LineCap.Round;
                        pen.EndCap = System.Drawing.Drawing2D.LineCap.Round;
                        penInner.StartCap = System.Drawing.Drawing2D.LineCap.Round;
                        penInner.EndCap = System.Drawing.Drawing2D.LineCap.Round;
                        g.DrawLine(pen, sx, sy, ex, ey);
                        g.DrawLine(penInner, sx, sy, ex, ey);
                    }
                }
            }
            catch { }
        }

        /// <summary>
        /// Starts a timer that periodically attempts to spawn power items (ups/downs)
        /// based on the current score, configured probabilities and dynamic caps.
        /// </summary>
        private void StartPowerItemSpawner()
        {
            powerItemSpawner = new System.Windows.Forms.Timer();
            // make spawns more frequent and likely
            powerItemSpawner.Interval = 3000;
            powerItemSpawner.Tick += (s, e) =>
            {
                // do not spawn while the engine is paused or the game ended
                try { if (engine.IsPaused || gameEndedFlag) return; } catch { }
                // remove any inactive entries
                powerItems.RemoveAll(p => p == null || !p.Active);

                // spawn conditions: score threshold and keep a cap to avoid overwhelming game
                int score = engine.GetElapsedTime();
                // dynamic cap increases with score
                int dynamicCap = MaxSimultaneousPowerItems;
                if (score >= 100) dynamicCap = Math.Max(dynamicCap, MaxSimultaneousPowerItems + 1);
                if (score >= 200) dynamicCap = Math.Max(dynamicCap, MaxSimultaneousPowerItems + 2);

                if (score >= spawnScoreThreshold && powerItems.Count < dynamicCap)
                {
                    // spawn chance increases as the player's score grows
                    // increase base chance so items appear more often
                    double baseChance = 0.8;
                    double multiplier = 1.0;
                    if (score >= 100) multiplier *= 2.0; // double chance at 100
                    if (score >= 200) multiplier *= 2.0; // double again at 200 (total x4)

                    double chance = Math.Min(1.0, baseChance * multiplier);

                    // randomize whether to spawn this tick to keep gameplay varied
                    if (rnd.NextDouble() < chance)
                    {
                        // determine UP/DOWN probabilities based on score
                        double upProb;
                        if (score < 100) upProb = 0.75; // under 100: 75% up
                        else if (score < 200) upProb = 0.5; // 100-199: 50% up
                        else upProb = 0.25; // 200+: 25% up

                        bool spawnUp = rnd.NextDouble() < upProb;

                        List<Func<Form3, PowerDownBase>> pool = spawnUp ? powerUpFactories : powerDownFactories;

                        if (pool.Count > 0)
                        {
                            int idx = rnd.Next(0, pool.Count);
                            var pd = pool[idx](this);
                            pd.Spawn();
                            powerItems.Add(pd);
                        }
                    }
                }

                powerItemSpawner.Interval = rnd.Next(3000, 8000);
            };
            powerItemSpawner.Start();
        }

