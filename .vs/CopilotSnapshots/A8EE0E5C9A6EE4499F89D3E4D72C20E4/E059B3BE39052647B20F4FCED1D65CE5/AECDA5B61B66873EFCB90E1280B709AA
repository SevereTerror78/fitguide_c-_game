        /// <summary>
        /// Constructs the game form, initializes UI and game engine, registers power item factories
        /// and starts the power item spawner and background UI update task.
        /// </summary>
        /// <param name="username">Player username to display/save scores for.</param>
        /// <param name="userManager">User manager instance for account operations.</param>
        /// <param name="scoreManager">Score manager instance for persisting scores.</param>
        public Form3(string username, UserManager userManager, ScoreManager scoreManager)
        {
            InitializeComponent();

            this.username = username ?? "anonymous";
            this.userManager = userManager;
            this.scoreManager = scoreManager;

            InitUI();

            engine = new GameEngine(this);
            engine.OnElapsedTimeChanged += Engine_OnElapsedTimeChanged;
            engine.OnShootBullet += Engine_OnShootBullet;
            engine.OnGameEnded += Engine_OnGameEnded;

            engine.Start();

            // register available item types — add here as you implement new ones
            powerDownFactories.Add(f => new PowerDownScore(f));
            powerDownFactories.Add(f => new PowerDownSlow(f));
            powerDownFactories.Add(f => new PowerDownKill(f));

            powerUpFactories.Add(f => new PowerUpScore(f));
            powerUpFactories.Add(f => new PowerUpBig(f));

            // initial power items list is empty; spawner will create instances
            StartPowerItemSpawner();

            Task.Run(() =>
            {
                Thread.Sleep(200);
                while (true)
                {
                    if (this.IsDisposed) break;
                    try
                    {
                        this.Invoke((MethodInvoker)delegate
                        {
                            Rectangle bounds = new Rectangle(this.Left, this.Top, this.Width, this.Height);
                            bool ended = false;

                            // Only shrink the frame when the engine is not paused
                            try { if (!engine.IsPaused) ended = engine.ShrinkFrame(ref bounds); }
                            catch { }

                            if (!ended)
                            {
                                this.Width = bounds.Width;
                                this.Height = bounds.Height;
                                this.Left = bounds.Left;
                                this.Top = bounds.Top;

                                playerBtn.Location = new Point(this.ClientSize.Width / 2 - playerBtn.Width / 2,
                                                               this.ClientSize.Height / 2 - playerBtn.Height / 2);
                            }
                        });
                    }
                    catch { break; }

                    Thread.Sleep(25);
                }
            });
        }

        /// <summary>
        /// Initialize the main UI elements for the game form (player button, timer label)
        /// and set basic form properties (size, cursor).
        /// </summary>
        private void InitUI()
        {
            this.AutoSize = false;
            this.MinimizeBox = false;
            this.MaximizeBox = false;
            // prevent user resizing with mouse - keep programmatic resize (engine) working
            this.FormBorderStyle = FormBorderStyle.FixedSingle;
            this.Size = new Size(1000, 1000);

            // use crosshair cursor while playing
            try { this.Cursor = Cursors.Cross; } catch { }

            playerBtn = new Button { Width = 55, Height = 55 };
            // center initial location
            playerBtn.Location = new Point(this.Width / 2 - playerBtn.Width / 2, this.Height / 2 - playerBtn.Height / 2);
            this.Controls.Add(playerBtn);
            // add transparent overlay control to draw barrel above everything without intercepting clicks
            try
            {
                var overlay = new OverlayControl(playerBtn) { BarrelLength = barrelLength };
                this.Controls.Add(overlay);
                overlay.BringToFront();
            }
            catch { }

            timerLabel = new Label { Text = "0", Width = 100, Height = 50, Location = new Point(10, 10), Anchor = AnchorStyles.Top | AnchorStyles.Left };
            this.Controls.Add(timerLabel);

            // enable double buffering for smooth barrel rendering
            try
            {
                this.SetStyle(ControlStyles.OptimizedDoubleBuffer | ControlStyles.UserPaint | ControlStyles.AllPaintingInWmPaint, true);
                this.UpdateStyles();
            }
            catch { }

            // start a small timer to track cursor and repaint barrel (works even when mouse over child controls)
            barrelTarget = new PointF(this.ClientSize.Width / 2f, this.ClientSize.Height / 2f);
            barrelTimer = new System.Windows.Forms.Timer();
            barrelTimer.Interval = 15;
            barrelTimer.Tick += (s, e) =>
            {
                try
                {
                    var p = this.PointToClient(Cursor.Position);
                    barrelTarget = new PointF(p.X, p.Y);
                    this.Invalidate();
                }
                catch { }
            };
            barrelTimer.Start();
        }

